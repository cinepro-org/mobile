# Copy to `.env` and fill in. Expo injects only variables prefixed with EXPO_PUBLIC_
# https://docs.expo.dev/guides/environment-variables/

# TMDB API v3 key (browse, search, artwork). Required for catalog screens.
EXPO_PUBLIC_TMDB_API_KEY=

# Your CinePro Core (OMSS) base URL — no trailing slash.
EXPO_PUBLIC_CINEPRO_BASE_URL=http://localhost:3000
