{
  "name": "cinestream",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "android:run:release": "expo run:android --variant release",
    "android:release": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-android-release.ps1 -Target both",
    "android:release:phone": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-android-release.ps1 -Target phone",
    "android:release:tv": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-android-release.ps1 -Target tv",
    "android:release:phone:dirty": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-android-release.ps1 -Target phone -Dirty",
    "android:release:tv:dirty": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-android-release.ps1 -Target tv -Dirty",
    "android:apk:dirty": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-android-release.ps1 -Target phone -Dirty",
    "android:apk": "cd android && gradlew.bat assembleRelease",
    "android:apk:subst": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-android-release.ps1 -Target phone",
    "android:bundle:subst": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-android-release.ps1 -GradleTask bundleRelease -Target phone",
    "android:bundle:release": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-android-release.ps1 -GradleTask bundleRelease -Target both",
    "ios": "expo run:ios",
    "web": "expo start --web"
  },
  "expo": {
    "install": {
      "exclude": [
        "react-native"
      ]
    }
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.11",
    "@react-navigation/drawer": "^7.9.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.12",
    "@shopify/flash-list": "^2.3.1",
    "@tanstack/react-query": "^5.100.9",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.33",
    "expo-blur": "~15.0.8",
    "expo-brightness": "~14.0.8",
    "expo-constants": "~18.0.13",
    "expo-image": "~3.0.11",
    "expo-keep-awake": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-screen-orientation": "~9.0.9",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "npm:react-native-tvos@0.81-stable",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-video": "^6.19.2",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "^0.8.3",
    "tailwindcss": "^3.4.19",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@react-native-tvos/config-tv": "^0.1.4",
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
