{
  "expo": {
    "name": "cinestream",
    "slug": "cinestream",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/logo/favicon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo/dark.png",
      "resizeMode": "contain",
      "backgroundColor": "#07080d"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cinestream.app",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "android": {
      "package": "com.cinestream.app",
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo/favicon.png",
        "backgroundColor": "#07080d"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/logo/favicon.png",
      "bundler": "metro"
    },
    "plugins": ["react-native-video", "./plugins/withAndroidCleartextTraffic.js"]
  }
}
